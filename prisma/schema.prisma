// generator client {
//   provider = "prisma-client"
//   // output   = "../node_modules/prisma/prisma-client"
// }

generator client {
  provider = "prisma-client-js"

  output   = "../node_modules/.prisma/prisma-client"
  
}

datasource db {
  provider = "postgresql"
  
}


model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  createdAt   DateTime @default(now())
}